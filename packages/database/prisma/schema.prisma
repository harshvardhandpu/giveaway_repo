generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

enum GiveawayStatus { ACTIVE COMPLETED DELETED UNKNOWN }
enum EvidenceType { WINNER_ANNOUNCEMENT WINNER_CONFIRMATION QUOTE_TWEET TRANSACTION_PROOF SCREENSHOT_PROOF COMMUNITY_FEEDBACK HISTORICAL_GIVEAWAY SCAM_REPORT OTHER }
enum EvidenceRelationshipType { CREATED WON_BY CONFIRMED_BY SUPPORTS CONTRADICTS REFERENCES }
enum RiskLevel { LOW MEDIUM HIGH }
enum EvaluationLabel { LEGITIMATE SUSPICIOUS SCAM UNKNOWN }

model User {
  id String @id @default(cuid())
  email String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  keywordWatchlists KeywordWatchlist[]
  creatorWatchlists CreatorWatchlist[]
  sessions Session[]
  passwordHash String?
  role UserRole @default(USER)
  emailVerifiedAt DateTime?
}
enum UserRole { USER ADMIN }
model Session { id String @id @default(cuid()) userId String user User @relation(fields:[userId],references:[id],onDelete:Cascade) refreshTokenHash String @unique expiresAt DateTime createdAt DateTime @default(now()) revokedAt DateTime? @@index([userId,expiresAt]) }

model KeywordWatchlist {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword String
  enabled Boolean @default(true)
  lastChecked DateTime?
  createdAt DateTime @default(now())
  @@unique([userId, keyword])
  @@index([enabled, lastChecked])
}

model CreatorWatchlist {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  creatorId String
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  enabled Boolean @default(true)
  lastChecked DateTime?
  createdAt DateTime @default(now())
  @@unique([userId, creatorId])
  @@index([enabled, lastChecked])
}

model Creator {
  id String @id @default(cuid())
  username String @unique
  displayName String?
  trustScore Int @default(50)
  riskLevel RiskLevel @default(MEDIUM)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  giveaways Giveaway[]
  reports AIReport[]
  watchlists CreatorWatchlist[]
  scoreSnapshots TrustScoreSnapshot[]
  @@index([trustScore])
}

model TrustScoreSnapshot {
  id String @id @default(cuid())
  creatorId String
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  score Int
  riskLevel RiskLevel
  reasons Json
  createdAt DateTime @default(now())
  @@index([creatorId, createdAt])
}

model Giveaway {
  id String @id @default(cuid())
  creatorId String
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title String
  sourceUrl String? @unique
  tweetText String
  token String?
  amount String?
  requirements String?
  deadline DateTime?
  status GiveawayStatus @default(UNKNOWN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  evidence Evidence[]
  winners Winner[]
  reports AIReport[]
  @@index([creatorId, status])
  @@index([deadline])
}

model Evidence {
  id String @id @default(cuid())
  giveawayId String
  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  type EvidenceType
  url String
  description String
  confidence Float
  discoveredAt DateTime @default(now())
  @@index([giveawayId, type])
}

model EvidenceRelationship {
  id String @id @default(cuid())
  sourceId String
  targetId String
  relationshipType EvidenceRelationshipType
  confidence Float
  createdAt DateTime @default(now())
  @@unique([sourceId, targetId, relationshipType])
  @@index([targetId, relationshipType])
}

model Winner {
  id String @id @default(cuid())
  giveawayId String
  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  username String
  confirmationUrl String?
  confirmedAt DateTime?
  @@unique([giveawayId, username])
}

model AIReport {
  id String @id @default(cuid())
  creatorId String
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  giveawayId String?
  giveaway Giveaway? @relation(fields: [giveawayId], references: [id], onDelete: SetNull)
  score Int
  riskLevel RiskLevel
  summary String
  reasons Json
  modelVersion String @default("phase1")
  createdAt DateTime @default(now())
  @@index([creatorId, createdAt])
}

model EvaluationDataset { id String @id @default(cuid()) name String @unique description String? createdAt DateTime @default(now()) cases EvaluationCase[] }
model EvaluationCase { id String @id @default(cuid()) datasetId String dataset EvaluationDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade) creatorUsername String giveawayUrl String? expectedResult Json? humanLabel EvaluationLabel @default(UNKNOWN) notes String? createdAt DateTime @default(now()) }
model ScoreExperiment { id String @id @default(cuid()) scoreVersion String inputEvidence Json outputScore Int result EvaluationLabel createdAt DateTime @default(now()) @@index([scoreVersion, createdAt]) }
model EvidenceQualityReport { id String @id @default(cuid()) evidenceType EvidenceType accuracy Float falseEvidenceRate Float sampleSize Int createdAt DateTime @default(now()) }
